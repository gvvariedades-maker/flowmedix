# ============================================================================
# VARIÁVEIS DE AMBIENTE - AVANT
# ============================================================================
# Copie este arquivo para .env.local e preencha com seus valores

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Google Gemini API (Opcional - para funcionalidades de IA)
GOOGLE_API_KEY=your_google_api_key

# Environment
NODE_ENV=development

# Admin (opcional - fallback: gvvariedades@gmail.com)
ADMIN_EMAIL=seu_email_admin@exemplo.com

# Segurança - obrigatório em produção
WEBHOOK_SECRET=seu_secret_para_webhooks
METRICS_SECRET=seu_secret_para_metricas

# ============================================================================
# NOTAS:
# - NUNCA commite o arquivo .env.local no Git
# - NEXT_PUBLIC_* são expostas ao cliente, use com cuidado
# - SERVICE_ROLE_KEY tem acesso total ao banco, mantenha segura
# ============================================================================
